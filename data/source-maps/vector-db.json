{
  "source": "vector-db:api",
  "match": {
    "vendor": "vector_db",
    "surface": "api"
  },
  "parser_version": "config:vector-db@1",
  "stable_id": {
    "fields": ["vendor", "batch.id"]
  },
  "actor_ref": {
    "kind": "email",
