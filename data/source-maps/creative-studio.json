{
  "source": "creative-studio:web",
  "match": {
    "vendor": "creative_studio",
    "surface": "web"
  },
  "parser_version": "config:creative-studio@1",
  "stable_id": {
    "fields": ["vendor", "job.id"]
  },
  "actor_ref": {
    "kind": "email",
    "path": "user.email"
  },
  "tool_ref": {
    "vendor": "creative_studio",
    "surface": "web",
    "model_path": "job.model"
  },
  "occurred_at": "job.created_at",
  "activity_type": "image_generation",
  "usage_measures": {
    "images": "job.outputs",
    "input_tokens": "usage.prompt_tokens",
    "output_tokens": "usage.image_units"
  },
  "content_refs": [
    {
      "role": "prompt",
      "path": "job.prompt"
    }
  ],
  "cost": {
    "path": "billing.usd",
    "authority": "source_payload"
  }
}
