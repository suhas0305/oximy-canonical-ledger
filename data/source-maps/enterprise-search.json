{
  "source": "enterprise-search:web",
  "match": {
    "vendor": "enterprise_search",
    "surface": "web"
  },
  "parser_version": "config:enterprise-search@1",
  "stable_id": {
    "fields": ["vendor", "query.id"]
  },
  "actor_ref": {
    "kind": "email",
    "path": "principal.email"
  },
  "tool_ref": {
    "vendor": "enterprise_search",
    "surface": "web",
    "model_path": "answer.model"
  },
  "occurred_at": "query.time",
  "activity_type": "retrieval_search",
  "usage_measures": {
    "input_tokens": "usage.input_tokens",
    "output_tokens": "usage.output_tokens",
    "documents_retrieved": "usage.documents_retrieved"
  },
  "content_refs": [
    {
      "role": "query",
      "path": "query.text"
    }
  ],
  "cost": {
    "path": "billing.usd",
    "authority": "source_payload"
  }
}
